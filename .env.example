# ══════════════════════════════════════════════════════════════════
# ResultOps — Environment Variables
# Copy this file: cp .env.example .env
# Then fill in your own values below.
# ══════════════════════════════════════════════════════════════════

# ── Firebase Configuration ────────────────────────────────────────
FIREBASE_KEY_PATH=firebase_key.json

# ── 3-Tier Authentication — SHA-256 Hashes ────────────────────────
# Generate hash for any password:
#   python -c "import hashlib; print(hashlib.sha256('your_password'.encode()).hexdigest())"
#
# Tiers:
#   READ  → View analytics dashboard, history (view only)
#   WRITE → Upload PDFs, parse, save to database
#   ADMIN → System stats, delete records from history

READ_PASSWORD_HASH=5e884898da28047151d0e56f8dc6292773603d0d6aabbdd62a11ef721d1542d8
WRITE_PASSWORD_HASH=5e884898da28047151d0e56f8dc6292773603d0d6aabbdd62a11ef721d1542d8
ADMIN_PASSWORD_HASH=5e884898da28047151d0e56f8dc6292773603d0d6aabbdd62a11ef721d1542d8

# ⚠️  Default hash above is for "password" — CHANGE ALL THREE before deploying!

# ── Legacy (backward compatibility) ──────────────────────────────
# Only used if ADMIN_PASSWORD_HASH is not set
ADMIN_PASSWORD=password